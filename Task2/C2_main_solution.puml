@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title C2 - Edge-first контейнерная архитектура

System_Ext(ip_cameras, "IP-камеры", "RTSP/ONVIF")
System_Ext(feeders, "Кормушки и поилки", "Разные производители")
System_Ext(water_filters, "Фильтрация воды", "Фильтры и датчики")
System_Ext(feed_stock_sensors, "Датчики запасов корма", "Весы и уровнемеры")
System_Ext(erp, "ERP / 1С:Агро", "Учет")
System_Ext(bi, "BI", "Отчеты")
System_Ext(notification_channels, "Каналы уведомлений", "SMS, мессенджеры, сирены")

System_Boundary(farm_agent, "Farm Agent на каждой ферме") {
  Container(local_api_gateway, "Local API Gateway", "REST/gRPC", "Локальный API управления и диагностики")
  Container(video_stream_adapter, "Video Stream Adapter", "RTSP/ONVIF", "Прием видеопотоков")
  Container(video_analytics, "Video Analytics Service", "ML runtime", "Real-time анализ видео")
  Container(local_incident, "Local Incident Service", "Service", "Локальная обработка инцидентов")
  Container(animal_monitoring, "Animal Monitoring Service", "Service", "Здоровье, гибель, беспокойство")
  Container(feeding_watering, "Feeding & Watering Service", "Service", "Управление кормушками и поилками")
  Container(water_monitoring, "Water Monitoring Service", "Service", "Контроль фильтрации воды")
  Container(feed_inventory, "Feed Inventory Service", "Service", "Остатки и прогноз расхода")
  Container(device_adapter, "Device Adapter Service", "Protocol adapters", "Адаптеры устройств")
  Container(local_notification, "Local Notification Service", "Service", "Локальные уведомления без интернета")
  Container(local_broker, "Local Message Broker", "RabbitMQ/MQTT", "Локальная событийная шина")
  ContainerDb(local_db, "Local Operational DB", "PostgreSQL/TimescaleDB", "Операционные данные и временные ряды")
  Container(sync_service, "Sync Service", "Service", "Синхронизация с центром")
}

System_Boundary(central_platform, "Центральная платформа") {
  Container(central_api_gateway, "Central API Gateway", "REST/gRPC", "Единая точка API")
  Container(web_portal, "Web Portal", "Web", "Рабочее место пользователей")
  Container(mobile_api, "Mobile API", "REST", "API для мобильного приложения")
  Container(identity_access, "Identity & Access Service", "Keycloak/OAuth2/OIDC", "Роли и доступ")
  Container(farm_registry, "Farm Registry Service", "Service", "Реестр ферм и агентов")
  Container(central_incident, "Central Incident Service", "Service", "Центральная обработка инцидентов")
  Container(metrics_service, "Metrics Service", "Service", "Базовые и пользовательские метрики")
  Container(analytics_service, "Analytics Service", "Service", "Аналитика и прогнозы")
  Container(notification_orchestrator, "Notification Orchestrator", "Service", "Маршрутизация уведомлений")
  Container(integration_service, "Integration Service", "Service", "Интеграция с ERP, BI и IT-ландшафтом")
  Container(central_event_bus, "Central Event Bus", "Kafka", "Центральная событийная шина")
  ContainerDb(central_db, "Central Operational DB", "PostgreSQL", "Операционные данные")
  ContainerDb(data_lake, "Data Lake", "MinIO/S3", "Сырые события, видеофрагменты и датасеты")
  ContainerDb(dwh, "Data Warehouse", "ClickHouse", "Витрины и агрегаты")
}

Rel(ip_cameras, video_stream_adapter, "Передают видео", "RTSP/ONVIF")
Rel(video_stream_adapter, video_analytics, "Передает кадры")
Rel(video_analytics, local_incident, "Публикует признаки инцидентов")
Rel(device_adapter, feeders, "Команды и телеметрия")
Rel(device_adapter, water_filters, "Состояние фильтрации")
Rel(device_adapter, feed_stock_sensors, "Остатки корма")
Rel(feeding_watering, device_adapter, "Управляет устройствами")
Rel(water_monitoring, device_adapter, "Читает показатели воды")
Rel(feed_inventory, device_adapter, "Читает остатки")
Rel(local_incident, local_broker, "Публикует события")
Rel(animal_monitoring, local_broker, "Публикует метрики животных")
Rel(feeding_watering, local_broker, "Публикует команды и события")
Rel(water_monitoring, local_broker, "Публикует показатели")
Rel(feed_inventory, local_broker, "Публикует остатки и прогноз")
Rel(local_broker, local_db, "Записывает события")
Rel(local_broker, local_notification, "Передает тревоги")
Rel(local_notification, notification_channels, "Отправляет локальные уведомления")
Rel(local_db, sync_service, "Отдает несинхронизированные данные")
Rel(sync_service, central_event_bus, "Синхронизирует события и агрегаты")

Rel(web_portal, central_api_gateway, "Использует")
Rel(mobile_api, central_api_gateway, "Использует")
Rel(central_api_gateway, identity_access, "Проверяет токены и роли")
Rel(central_api_gateway, central_incident, "Запрашивает инциденты")
Rel(central_api_gateway, metrics_service, "Запрашивает метрики")
Rel(central_api_gateway, farm_registry, "Управляет фермами и агентами")
Rel(central_event_bus, central_incident, "Передает инциденты")
Rel(central_event_bus, metrics_service, "Передает метрики")
Rel(central_event_bus, data_lake, "Сохраняет сырые данные")
Rel(central_event_bus, dwh, "Передает агрегаты")
Rel(central_incident, central_db, "Хранит инциденты")
Rel(metrics_service, central_db, "Хранит определения метрик")
Rel(analytics_service, dwh, "Читает витрины")
Rel(notification_orchestrator, notification_channels, "Отправляет внешние уведомления")
Rel(integration_service, erp, "Синхронизирует данные")
Rel(integration_service, bi, "Публикует витрины")
Rel(integration_service, central_event_bus, "Потребляет события")

LAYOUT_WITH_LEGEND()
@enduml
